{
  "description": "Chivora IVR - welcome message + 3-option menu (new enquiry / partner-SI / existing client), live call forwarding with voicemail fallback",
  "states": [
    {
      "name": "Trigger",
      "type": "trigger",
      "transitions": [
        { "event": "incomingMessage" },
        { "event": "incomingCall", "next": "gather_menu" },
        { "event": "incomingConversationMessage" }
      ],
      "properties": {
        "offset": { "x": 0, "y": 0 }
      }
    },
    {
      "name": "gather_menu",
      "type": "gather-input-on-call",
      "transitions": [
        { "event": "keypress", "next": "split_menu" },
        { "event": "timeout", "next": "voicemail_general" }
      ],
      "properties": {
        "offset": { "x": 0, "y": 200 },
        "loop": "2",
        "finish_on_key": "#",
        "num_digits": "1",
        "profanity_filter": "false",
        "say": "Welcome to Chivora, where your Dynamics 365 data migration gets handled cleanly, completely, and on time. We specialise exclusively in moving business data from SAP, Oracle, Sage, N A V and other legacy systems into Dynamics 365. Nothing else. To direct your call: press 1 if you're planning or running a D 3 6 5 migration and want to talk to us directly. Press 2 if you're a Microsoft Partner or Systems Integrator looking for specialist migration resource. Press 3 if you're an existing client and need support. You can press your selection now.",
        "timeout": "12",
        "voice": "Polly.Amy-Neural"
      }
    },
    {
      "name": "split_menu",
      "type": "split-based-on",
      "transitions": [
        { "event": "noMatch", "next": "invalid_option" },
        {
          "event": "match",
          "next": "connecting_enquiry",
          "conditions": [
            { "friendly_name": "If value equal_to 1", "type": "equal_to", "value": "1", "arguments": ["{{widgets.gather_menu.Digits}}"] }
          ]
        },
        {
          "event": "match",
          "next": "connecting_partner",
          "conditions": [
            { "friendly_name": "If value equal_to 2", "type": "equal_to", "value": "2", "arguments": ["{{widgets.gather_menu.Digits}}"] }
          ]
        },
        {
          "event": "match",
          "next": "connecting_client",
          "conditions": [
            { "friendly_name": "If value equal_to 3", "type": "equal_to", "value": "3", "arguments": ["{{widgets.gather_menu.Digits}}"] }
          ]
        }
      ],
      "properties": {
        "offset": { "x": 0, "y": 400 },
        "input": "{{widgets.gather_menu.Digits}}"
      }
    },
    {
      "name": "invalid_option",
      "type": "say-play",
      "transitions": [
        { "event": "audioComplete", "next": "voicemail_general" }
      ],
      "properties": {
        "offset": { "x": -400, "y": 600 },
        "say": "Sorry, I didn't get a valid option. Let me take a message instead.",
        "voice": "Polly.Amy-Neural"
      }
    },

    {
      "name": "connecting_enquiry",
      "type": "say-play",
      "transitions": [
        { "event": "audioComplete", "next": "dial_enquiry" }
      ],
      "properties": {
        "offset": { "x": 100, "y": 600 },
        "say": "Connecting you now. Please hold.",
        "voice": "Polly.Amy-Neural"
      }
    },
    {
      "name": "dial_enquiry",
      "type": "connect-call-to",
      "transitions": [
        { "event": "callCompleted", "next": "check_enquiry" },
        { "event": "hangup", "next": "goodbye" }
      ],
      "properties": {
        "offset": { "x": 100, "y": 750 },
        "noun": "number",
        "to": "+447918554877",
        "caller_id": "{{flow.channel.address}}",
        "timeout": "60"
      }
    },
    {
      "name": "check_enquiry",
      "type": "split-based-on",
      "transitions": [
        { "event": "noMatch", "next": "voicemail_enquiry" },
        {
          "event": "match",
          "next": "goodbye",
          "conditions": [
            { "friendly_name": "If value equal_to completed", "type": "equal_to", "value": "completed", "arguments": ["{{widgets.dial_enquiry.DialCallStatus}}"] }
          ]
        }
      ],
      "properties": {
        "offset": { "x": 100, "y": 900 },
        "input": "{{widgets.dial_enquiry.DialCallStatus}}"
      }
    },
    {
      "name": "voicemail_enquiry",
      "type": "say-play",
      "transitions": [
        { "event": "audioComplete", "next": "record_enquiry" }
      ],
      "properties": {
        "offset": { "x": 100, "y": 1050 },
        "say": "Sorry we missed you. After the tone, please leave your name, company, source system, and the best number to reach you. Sunday will call you back within one business day.",
        "voice": "Polly.Amy-Neural"
      }
    },
    {
      "name": "record_enquiry",
      "type": "record-voicemail",
      "transitions": [
        { "event": "recordingComplete", "next": "goodbye" },
        { "event": "noAudio", "next": "goodbye" },
        { "event": "hangup", "next": "goodbye" }
      ],
      "properties": {
        "offset": { "x": 100, "y": 1200 },
        "play_beep": "true",
        "transcribe": true,
        "max_length": "120",
        "silence_timeout": "5",
        "trim": "true"
      }
    },

    {
      "name": "connecting_partner",
      "type": "say-play",
      "transitions": [
        { "event": "audioComplete", "next": "dial_partner" }
      ],
      "properties": {
        "offset": { "x": 450, "y": 600 },
        "say": "Connecting you now. Please hold.",
        "voice": "Polly.Amy-Neural"
      }
    },
    {
      "name": "dial_partner",
      "type": "connect-call-to",
      "transitions": [
        { "event": "callCompleted", "next": "check_partner" },
        { "event": "hangup", "next": "goodbye" }
      ],
      "properties": {
        "offset": { "x": 450, "y": 750 },
        "noun": "number",
        "to": "+447918554877",
        "caller_id": "{{flow.channel.address}}",
        "timeout": "60"
      }
    },
    {
      "name": "check_partner",
      "type": "split-based-on",
      "transitions": [
        { "event": "noMatch", "next": "voicemail_partner" },
        {
          "event": "match",
          "next": "goodbye",
          "conditions": [
            { "friendly_name": "If value equal_to completed", "type": "equal_to", "value": "completed", "arguments": ["{{widgets.dial_partner.DialCallStatus}}"] }
          ]
        }
      ],
      "properties": {
        "offset": { "x": 450, "y": 900 },
        "input": "{{widgets.dial_partner.DialCallStatus}}"
      }
    },
    {
      "name": "voicemail_partner",
      "type": "say-play",
      "transitions": [
        { "event": "audioComplete", "next": "record_partner" }
      ],
      "properties": {
        "offset": { "x": 450, "y": 1050 },
        "say": "Sorry we missed you. After the tone, please leave your name, your firm, the client and D 3 6 5 platform involved, and the best number to reach you. Sunday will call you back within one business day.",
        "voice": "Polly.Amy-Neural"
      }
    },
    {
      "name": "record_partner",
      "type": "record-voicemail",
      "transitions": [
        { "event": "recordingComplete", "next": "goodbye" },
        { "event": "noAudio", "next": "goodbye" },
        { "event": "hangup", "next": "goodbye" }
      ],
      "properties": {
        "offset": { "x": 450, "y": 1200 },
        "play_beep": "true",
        "transcribe": true,
        "max_length": "120",
        "silence_timeout": "5",
        "trim": "true"
      }
    },

    {
      "name": "connecting_client",
      "type": "say-play",
      "transitions": [
        { "event": "audioComplete", "next": "dial_client" }
      ],
      "properties": {
        "offset": { "x": 800, "y": 600 },
        "say": "Connecting you now. Please hold.",
        "voice": "Polly.Amy-Neural"
      }
    },
    {
      "name": "dial_client",
      "type": "connect-call-to",
      "transitions": [
        { "event": "callCompleted", "next": "check_client" },
        { "event": "hangup", "next": "goodbye" }
      ],
      "properties": {
        "offset": { "x": 800, "y": 750 },
        "noun": "number",
        "to": "+447918554877",
        "caller_id": "{{flow.channel.address}}",
        "timeout": "60"
      }
    },
    {
      "name": "check_client",
      "type": "split-based-on",
      "transitions": [
        { "event": "noMatch", "next": "voicemail_client" },
        {
          "event": "match",
          "next": "goodbye",
          "conditions": [
            { "friendly_name": "If value equal_to completed", "type": "equal_to", "value": "completed", "arguments": ["{{widgets.dial_client.DialCallStatus}}"] }
          ]
        }
      ],
      "properties": {
        "offset": { "x": 800, "y": 900 },
        "input": "{{widgets.dial_client.DialCallStatus}}"
      }
    },
    {
      "name": "voicemail_client",
      "type": "say-play",
      "transitions": [
        { "event": "audioComplete", "next": "record_client" }
      ],
      "properties": {
        "offset": { "x": 800, "y": 1050 },
        "say": "Sorry we missed you. After the tone, please leave your name, company, a summary of the issue, and the best number to reach you. Sunday will call you back within one business day.",
        "voice": "Polly.Amy-Neural"
      }
    },
    {
      "name": "record_client",
      "type": "record-voicemail",
      "transitions": [
        { "event": "recordingComplete", "next": "goodbye" },
        { "event": "noAudio", "next": "goodbye" },
        { "event": "hangup", "next": "goodbye" }
      ],
      "properties": {
        "offset": { "x": 800, "y": 1200 },
        "play_beep": "true",
        "transcribe": true,
        "max_length": "120",
        "silence_timeout": "5",
        "trim": "true"
      }
    },

    {
      "name": "voicemail_general",
      "type": "say-play",
      "transitions": [
        { "event": "audioComplete", "next": "record_general" }
      ],
      "properties": {
        "offset": { "x": -400, "y": 800 },
        "say": "After the tone, please leave your name, company, and reason for calling, along with the best number to reach you. Sunday will call you back within one business day.",
        "voice": "Polly.Amy-Neural"
      }
    },
    {
      "name": "record_general",
      "type": "record-voicemail",
      "transitions": [
        { "event": "recordingComplete", "next": "goodbye" },
        { "event": "noAudio", "next": "goodbye" },
        { "event": "hangup", "next": "goodbye" }
      ],
      "properties": {
        "offset": { "x": -400, "y": 1000 },
        "play_beep": "true",
        "transcribe": true,
        "max_length": "120",
        "silence_timeout": "5",
        "trim": "true"
      }
    },
    {
      "name": "goodbye",
      "type": "say-play",
      "transitions": [],
      "properties": {
        "offset": { "x": 300, "y": 1350 },
        "say": "Thank you for calling Chivora. Goodbye.",
        "voice": "Polly.Amy-Neural"
      }
    }
  ],
  "initial_state": "Trigger",
  "flags": {
    "allow_concurrent_calls": true
  }
}
